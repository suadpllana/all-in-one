# ---------------------------------------------------------------------------
# Vault — environment variables
# Copy this file to `.env` and fill in your own keys. Never commit `.env`.
# All keys are optional: the app degrades gracefully and shows a helpful
# message for any category whose key is missing. The library always lives in
# localStorage; the optional Netlify sync function only relays it between
# your devices.
# ---------------------------------------------------------------------------

# TMDB — Movies, TV Shows, Documentaries.  https://www.themoviedb.org/settings/api
# Use the v3 "API Key" (short key). Required for movies/tv/documentaries.
VITE_TMDB_API_KEY=

# RAWG — Games.  https://rawg.io/apidocs
VITE_RAWG_API_KEY=

# Google Books — Books. Optional; the API works without a key at lower quota.
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_BOOKS_API_KEY=

# YouTube — Podcasts & video essays. YouTube Data API v3.
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
VITE_YOUTUBE_API_KEY=

# Anime (Jikan / AniList) needs no key.
# Books fall back to Open Library (no key) when Google Books is unavailable.

# Device sync needs no keys — it uses the Netlify Function in
# netlify/functions/sync.mjs (Netlify Blobs). It works on the deployed site
# or locally via `npx netlify dev`.
